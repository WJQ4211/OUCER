# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=haidaren

# JWT
JWT_SECRET=change_this_to_a_random_string
JWT_EXPIRES_IN=7d

# WeChat Mini Program
WECHAT_APPID=wxa472b6a14d9b2e99
WECHAT_SECRET=your_wechat_app_secret

# SMTP - QQ email for verification code
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_code
SMTP_FROM="Haidaren" <noreply@haidaren.com>

# Frontend
FRONTEND_URL=http://localhost:10086

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Skip DB for dev (set true to run without MySQL)
SKIP_DB=true
